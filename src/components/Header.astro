---
interface Props {
  lang?: string;
}

const { lang = 'pl' } = Astro.props;
const pathname = Astro.url.pathname;

const navLabels: Record<string, Record<string, string>> = {
  pl: { home: 'Strona Główna', dataMatrix: 'Data Matrix', services: 'Usługi', portfolio: 'Realizacje', contact: 'Kontakt' },
  en: { home: 'Home', dataMatrix: 'Data Matrix', services: 'Services', portfolio: 'Portfolio', contact: 'Contact' },
  ru: { home: 'Главная', dataMatrix: 'Data Matrix', services: 'Услуги', portfolio: 'Портфолио', contact: 'Контакт' },
};

const t = navLabels[lang] || navLabels.pl;
const prefix = lang === 'pl' ? '' : `/${lang}`;

const links = [
  { href: `${prefix}/`, label: t.home },
  { href: `${prefix}/data-matrix/`, label: t.dataMatrix },
  { href: `${prefix}/uslugi/`, label: t.services },
  { href: `${prefix}/realizacje/`, label: t.portfolio },
  { href: `${prefix}/kontakt/`, label: t.contact },
];

// Language switcher: derive base path from current URL
const basePath = pathname.replace(/^\/(en|ru)/, '') || '/';
const langLinks = [
  { code: 'PL', href: basePath, active: lang === 'pl' },
  { code: 'EN', href: `/en${basePath}`, active: lang === 'en' },
  { code: 'RU', href: `/ru${basePath}`, active: lang === 'ru' },
];
---

<header class="bg-white shadow-sm fixed w-full top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 flex items-center justify-between h-16">
    <a href={`${prefix}/`} class="flex items-center gap-3">
      <img src="/logo.png" alt="Drukarnia WIPP" class="h-10" />
      <span class="text-xl font-bold text-gray-800">WIPP <span class="text-gray-500 font-normal">Drukarnia</span></span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex gap-6">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-blue-700',
              pathname === link.href ? 'text-blue-700' : 'text-gray-600'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="hidden md:flex items-center gap-4">
      <!-- Language switcher -->
      <div class="flex items-center gap-1 text-xs">
        {langLinks.map((l, i) => (
          <>
            {i > 0 && <span class="text-gray-300">|</span>}
            <a
              href={l.href}
              class:list={[
                'font-medium transition-colors hover:text-blue-700',
                l.active ? 'text-blue-700' : 'text-gray-400'
              ]}
            >
              {l.code}
            </a>
          </>
        ))}
      </div>

      <!-- Phone CTA -->
      <a href="tel:+48604286423" class="inline-flex items-center gap-2 bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-blue-800 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        604 286 423
      </a>
    </div>

    <!-- Hamburger -->
    <button id="menu-toggle" class="md:hidden p-2" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="md:hidden hidden bg-white border-t">
    <ul class="px-4 py-3 space-y-2">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block py-2 text-sm font-medium transition-colors',
              pathname === link.href ? 'text-blue-700' : 'text-gray-600'
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li class="pt-2 border-t flex items-center justify-between">
        <a href="tel:+48604286423" class="py-2 text-sm font-semibold text-blue-700">604 286 423</a>
        <div class="flex items-center gap-2 text-xs">
          {langLinks.map((l, i) => (
            <>
              {i > 0 && <span class="text-gray-300">|</span>}
              <a
                href={l.href}
                class:list={[
                  'font-medium transition-colors',
                  l.active ? 'text-blue-700' : 'text-gray-400'
                ]}
              >
                {l.code}
              </a>
            </>
          ))}
        </div>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>

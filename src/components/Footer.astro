---
interface Props {
  lang?: string;
}

const { lang = 'pl' } = Astro.props;
const year = new Date().getFullYear();
const prefix = lang === 'pl' ? '' : `/${lang}`;

const t: Record<string, Record<string, string>> = {
  pl: {
    desc: 'Profesjonalna drukarnia cyfrowa w Białymstoku. Specjalizujemy się w druku naklejek, etykiet samoprzylepnych i kodów Data Matrix.',
    nav: 'Nawigacja',
    contact: 'Kontakt',
    home: 'Strona Główna',
    dataMatrix: 'Data Matrix',
    services: 'Usługi',
    portfolio: 'Realizacje',
    contactPage: 'Kontakt',
    hours: 'Pn-Pt: 07:00 - 15:00',
  },
  en: {
    desc: 'Professional digital printing house in Białystok. We specialize in printing stickers, self-adhesive labels, and Data Matrix codes.',
    nav: 'Navigation',
    contact: 'Contact',
    home: 'Home',
    dataMatrix: 'Data Matrix',
    services: 'Services',
    portfolio: 'Portfolio',
    contactPage: 'Contact',
    hours: 'Mon-Fri: 07:00 - 15:00',
  },
  ru: {
    desc: 'Профессиональная цифровая типография в Белостоке. Специализируемся на печати наклеек, самоклеящихся этикеток и кодов Data Matrix.',
    nav: 'Навигация',
    contact: 'Контакт',
    home: 'Главная',
    dataMatrix: 'Data Matrix',
    services: 'Услуги',
    portfolio: 'Портфолио',
    contactPage: 'Контакт',
    hours: 'Пн-Пт: 07:00 - 15:00',
  },
};

const l = t[lang] || t.pl;
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Company -->
      <div>
        <h3 class="text-white text-lg font-bold mb-3">Drukarnia WIPP</h3>
        <p class="text-sm leading-relaxed">{l.desc}</p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white text-lg font-bold mb-3">{l.nav}</h3>
        <ul class="space-y-2 text-sm">
          <li><a href={`${prefix}/`} class="hover:text-white transition-colors">{l.home}</a></li>
          <li><a href={`${prefix}/data-matrix/`} class="hover:text-white transition-colors">{l.dataMatrix}</a></li>
          <li><a href={`${prefix}/uslugi/`} class="hover:text-white transition-colors">{l.services}</a></li>
          <li><a href={`${prefix}/realizacje/`} class="hover:text-white transition-colors">{l.portfolio}</a></li>
          <li><a href={`${prefix}/kontakt/`} class="hover:text-white transition-colors">{l.contactPage}</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white text-lg font-bold mb-3">{l.contact}</h3>
        <address class="not-italic text-sm space-y-2">
          <p>ul. Kombatantów 7A<br />15-110 Białystok</p>
          <p>
            <a href="tel:+48604286423" class="hover:text-white transition-colors">604 286 423</a>
          </p>
          <p>
            <a href="mailto:wippdrukarnia@gmail.com" class="hover:text-white transition-colors">wippdrukarnia@gmail.com</a>
          </p>
          <p>{l.hours}</p>
        </address>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-gray-700 text-center text-sm text-gray-500">
      &copy; {year} Wipp Piotr Prokopiuk — Drukarnia Białystok. Wszelkie prawa zastrzeżone.
    </div>
  </div>
</footer>

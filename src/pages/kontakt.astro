---
import Base from '../layouts/Base.astro';
---

<Base
  title="Kontakt — Drukarnia WIPP Białystok | Kombatantów 7A"
  description="Skontaktuj się z Drukarnią WIPP w Białymstoku. Tel: 604 286 423. Adres: ul. Kombatantów 7A, 15-110 Białystok. Pn-Pt 8:00-16:00."
>

  <!-- Hero -->
  <section class="pt-24 pb-12 md:pt-32 md:pb-16 bg-gradient-to-br from-blue-800 to-blue-950 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4">Kontakt</h1>
      <p class="text-lg text-blue-100">Zadzwoń, napisz lub odwiedź nas. Chętnie przygotujemy wycenę.</p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4">

      <!-- Contact cards -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">

        <a href="tel:+48604286423" class="group bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6 text-center">
          <div class="w-14 h-14 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-700 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          </div>
          <h2 class="font-bold text-gray-800 mb-1">Telefon</h2>
          <p class="text-blue-700 font-semibold text-lg">604 286 423</p>
        </a>

        <a href="mailto:wippdrukarnia@gmail.com" class="group bg-white rounded-xl shadow-md hover:shadow-lg transition-shadow p-6 text-center">
          <div class="w-14 h-14 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-700 group-hover:text-white transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h2 class="font-bold text-gray-800 mb-1">Email</h2>
          <p class="text-blue-700 font-semibold text-sm">wippdrukarnia@gmail.com</p>
        </a>

        <div class="bg-white rounded-xl shadow-md p-6 text-center">
          <div class="w-14 h-14 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h2 class="font-bold text-gray-800 mb-1">Adres</h2>
          <p class="text-gray-600 text-sm">ul. Kombatantów 7A<br />15-110 Białystok</p>
        </div>

        <div class="bg-white rounded-xl shadow-md p-6 text-center">
          <div class="w-14 h-14 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h2 class="font-bold text-gray-800 mb-1">Godziny otwarcia</h2>
          <p class="text-gray-600 text-sm">Pn-Pt: 8:00 - 16:00<br />Sb-Nd: zamknięte</p>
        </div>

      </div>

      <!-- Email CTA -->
      <div class="bg-blue-50 rounded-2xl p-8 md:p-12 text-center mb-16">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">Napisz do nas</h2>
        <p class="text-gray-600 mb-6 max-w-xl mx-auto">
          Opisz swoje zamówienie — ilość, format, materiał, termin realizacji.
          Odpowiemy z wyceną tak szybko, jak to możliwe.
        </p>
        <a href="mailto:wippdrukarnia@gmail.com?subject=Zapytanie%20o%20wycenę"
          class="inline-flex items-center gap-2 bg-blue-700 text-white font-bold px-8 py-3 rounded-lg hover:bg-blue-800 transition-colors text-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          wippdrukarnia@gmail.com
        </a>
      </div>

      <!-- Map -->
      <div>
        <h2 class="text-2xl font-bold mb-6 text-center">Gdzie nas znajdziesz</h2>
        <div class="rounded-xl overflow-hidden shadow-md">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2005.6354698659102!2d23.159546482128956!3d53.150002268782195!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x471ffc3f8d5fdacd%3A0x1b11bab1ec2e71c2!2sWipp%20Piotr%20Prokopiuk!5e0!3m2!1spl!2spl!4v1748554345172!5m2!1spl!2spl"
            width="100%"
            height="400"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Lokalizacja Drukarni WIPP — Kombatantów 7A, Białystok">
          </iframe>
        </div>
        <div class="mt-4 text-center">
          <a href="https://www.google.com/maps/dir/?api=1&destination=Kombatantów+7A,+15-110+Białystok"
            target="_blank" rel="noopener"
            class="text-blue-700 font-semibold hover:underline">
            Wyznacz trasę &rarr;
          </a>
        </div>
      </div>

    </div>
  </section>

</Base>

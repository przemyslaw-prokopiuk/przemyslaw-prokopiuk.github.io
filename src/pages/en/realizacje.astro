---
import Base from '../../layouts/Base.astro';
---

<Base
  lang="en"
  title="Portfolio — our work | WIPP Printing House Białystok"
  description="See our work: stickers, labels, Data Matrix codes, business cards, flyers, posters, and custom t-shirts. WIPP Printing House Białystok."
>

  <!-- Hero -->
  <section class="pt-24 pb-12 md:pt-32 md:pb-16 bg-gradient-to-br from-blue-800 to-blue-950 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-extrabold mb-4">Our work</h1>
      <p class="text-lg text-blue-100">Examples of our projects — from Data Matrix codes to promotional materials.</p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4">

      <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
        {[
          { title: 'Data Matrix labels', desc: 'Individual Data Matrix codes on self-adhesive stickers' },
          { title: 'Product stickers', desc: 'Packaging labels with barcodes and graphics' },
          { title: 'Business cards', desc: 'Elegant business cards on coated paper' },
          { title: 'Advertising flyers', desc: 'Promotional materials in A5 and DL formats' },
          { title: 'Custom t-shirts', desc: 'Personalized t-shirts for companies and teams' },
          { title: 'Posters & banners', desc: 'Large-format poster and advertising material printing' },
        ].map(item => (
          <div class="bg-gray-100 rounded-xl overflow-hidden">
            <div class="aspect-[4/3] bg-gray-200 flex items-center justify-center">
              <div class="text-center text-gray-400 px-4">
                <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                <span class="text-sm">Photo coming soon</span>
              </div>
            </div>
            <div class="p-4">
              <h3 class="font-bold text-gray-800">{item.title}</h3>
              <p class="text-sm text-gray-600 mt-1">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-500 mb-6">Want to see more examples? Contact us — we'll be happy to show our portfolio.</p>
        <a href="/en/kontakt/" class="bg-blue-700 text-white font-bold px-8 py-3 rounded-lg hover:bg-blue-800 transition-colors">
          Contact us
        </a>
      </div>

    </div>
  </section>

</Base>

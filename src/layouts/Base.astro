---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  lang?: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const { title, description, lang = 'pl', canonical, ogImage, schema } = Astro.props;
const canonicalUrl = canonical || Astro.url.href;
const ogImg = ogImage || '/logo.png';
const localeMap: Record<string, string> = { pl: 'pl_PL', en: 'en_US', ru: 'ru_RU' };
const ogLocale = localeMap[lang] || 'pl_PL';
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Wipp Piotr Prokopiuk" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImg, Astro.site).href} />
  <meta property="og:locale" content={ogLocale} />
  <meta property="og:site_name" content="Drukarnia WIPP Białystok" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImg, Astro.site).href} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="apple-touch-icon" href="/logo.png" />

  <!-- Schema.org -->
  {schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}

  <slot name="head" />
</head>
<body class="min-h-screen flex flex-col bg-white text-gray-900 antialiased">
  <Header lang={lang} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer lang={lang} />
</body>
</html>
